# Copy this file to `.env` before running `docker compose up --build`.

# Frontend runtime
BACKEND_API_URL=http://backend:8000

# Backend application
APP_NAME=Elephant Agent API
API_V1_PREFIX=/api/v1
DATABASE_PATH=data/elephant_agent.db
CORS_ORIGINS=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
ALLOW_DRY_RUN=true
ECOMMERCE_NAME=Solidus Demo Store
ECOMMERCE_PLATFORM=Solidus
ECOMMERCE_STOREFRONT_URL=
ECOMMERCE_ADMIN_URL=
ECOMMERCE_SUPPORT_EMAIL=

# Multimodal LLM (OpenAI-compatible, OpenRouter-friendly)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SITE_URL=http://localhost:3000
OPENAI_APP_NAME=Elephant Agent
# OpenRouter example:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4.1-mini

# Fixed e-commerce codebase target
SOLIDUS_REPO_URL=https://github.com/solidusio/solidus.git
SOLIDUS_REPO_BRANCH=main
SOLIDUS_LOCAL_PATH=/opt/solidus/solidus
SOLIDUS_AUTO_CLONE=true

# Ticketing
LINEAR_API_KEY=
LINEAR_DEFAULT_TEAM_ID=
LINEAR_DEFAULT_TEAM_NAME=
LINEAR_CORE_TEAM_ID=
LINEAR_ADMIN_TEAM_ID=
LINEAR_API_TEAM_ID=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=tickets@example.com
CORE_TEAM_EMAIL=core@example.com
ADMIN_TEAM_EMAIL=admin@example.com
API_TEAM_EMAIL=api@example.com

# Communicator (Slack-compatible webhook or leave empty for mock mode)
COMMUNICATOR_WEBHOOK_URL=
CORE_COMM_CHANNEL=#solidus-core
ADMIN_COMM_CHANNEL=#solidus-admin
API_COMM_CHANNEL=#solidus-api

# Upload constraints
MAX_ATTACHMENTS=5
MAX_UPLOAD_BYTES=5000000
MAX_TOTAL_UPLOAD_BYTES=10000000
